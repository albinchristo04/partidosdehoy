---
import type { FaqItem } from '../lib/faq';

interface Props {
  items: FaqItem[];
}
const { items } = Astro.props;
---
<section class="faq">
  <h2>Preguntas frecuentes</h2>
  <dl>
    {items.map((item) => (
      <>
        <dt>{item.question}</dt>
        <dd>{item.answer}</dd>
      </>
    ))}
  </dl>
</section>
